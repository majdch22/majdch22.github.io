      "source": [
        "# PoC8 \u2014 addCell signature hunt + renderOutput fix + comms loopback + files.view\n",
        "Targets: get addCell working (10 signature variants), fix renderOutput with real area, comms loopback, files.view probe."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
